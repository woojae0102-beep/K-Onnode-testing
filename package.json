{
  "name": "onnode-realtime-demo",
  "private": true,
  "version": "5.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "scheduler:social": "node scripts/social-token-scheduler.cjs",
    "scheduler:knowledge": "node scripts/trainer-knowledge-scheduler.cjs",
    "collect:knowledge": "node -e \"require('./scripts/trainer-knowledge-scheduler.cjs').collectTrainerKnowledge().catch((e)=>{console.error(e);process.exit(1)})\"",
    "refresh:instagram": "node -e \"require('./scripts/social-token-scheduler.cjs').refreshInstagramTokens().catch((e)=>{console.error(e);process.exit(1)})\"",
    "refresh:tiktok": "node -e \"require('./scripts/social-token-scheduler.cjs').refreshTikTokTokens().catch((e)=>{console.error(e);process.exit(1)})\"",
    "generate-pwa-assets": "pwa-assets-generator --preset minimal2023 public/icons/source.svg"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "firebase": "^11.10.0",
    "firebase-admin": "^12.7.0",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "i18next": "^26.0.4",
    "lamejs": "^1.2.1",
    "lucide-react": "^0.468.0",
    "node-cron": "^4.2.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.2",
    "recharts": "^3.8.1",
    "three": "^0.169.0",
    "youtubei.js": "^14.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.2.0"
  }
}
