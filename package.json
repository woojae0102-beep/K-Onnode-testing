{
  "name": "onnode-realtime-demo",
  "private": true,
  "version": "5.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint src --quiet",
    "build": "npm run lint && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:render": "npx --yes tsx scripts/verify-skeleton-render.ts",
    "generate:choreography-stubs": "npx --yes tsx scripts/generate-choreography-stubs.ts",
    "scheduler:social": "node scripts/social-token-scheduler.cjs",
    "scheduler:knowledge": "node scripts/trainer-knowledge-scheduler.cjs",
    "collect:knowledge": "node -e \"require('./scripts/trainer-knowledge-scheduler.cjs').collectTrainerKnowledge().catch((e)=>{console.error(e);process.exit(1)})\"",
    "refresh:instagram": "node -e \"require('./scripts/social-token-scheduler.cjs').refreshInstagramTokens().catch((e)=>{console.error(e);process.exit(1)})\"",
    "refresh:tiktok": "node -e \"require('./scripts/social-token-scheduler.cjs').refreshTikTokTokens().catch((e)=>{console.error(e);process.exit(1)})\"",
    "generate-pwa-assets": "pwa-assets-generator --preset minimal2023 public/icons/source.svg",
    "copy:mediapipe-wasm": "node scripts/copy-mediapipe-wasm.cjs",
    "postinstall": "node scripts/copy-mediapipe-wasm.cjs"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "@ybd-project/ytdl-core": "^6.0.8",
    "bgutils-js": "^3.2.0",
    "firebase": "^11.10.0",
    "firebase-admin": "^12.7.0",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "i18next": "^26.0.4",
    "lamejs": "^1.2.1",
    "lucide-react": "^0.468.0",
    "mp4box": "^2.4.1",
    "node-cron": "^4.2.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.2",
    "recharts": "^3.8.1",
    "three": "^0.169.0",
    "youtubei.js": "^17.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.51.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tailwindcss-animate": "^1.0.7",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.2.0"
  }
}
