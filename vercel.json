{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/audition/:path*",
      "destination": "/api/audition?path=:path*"
    },
    {
      "source": "/api/monthly/:path*",
      "destination": "/api/monthly?path=:path*"
    },
    {
      "source": "/api/coaching/:path*",
      "destination": "/api/coaching?path=:path*"
    },
    {
      "source": "/api/tv/:path*",
      "destination": "/api/tv?path=:path*"
    },
    {
      "source": "/api/group/:path*",
      "destination": "/api/group?path=:path*"
    },
    {
      "source": "/api/knowledge/:path*",
      "destination": "/api/knowledge?path=:path*"
    },
    {
      "source": "/api/auth/social/:path*",
      "destination": "/api/auth/social?path=:path*"
    },
    {
      "source": "/oauth/callback/kakao",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/update-trending",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/cron/refresh-instagram-tokens",
      "schedule": "0 0 1,15 * *"
    },
    {
      "path": "/api/cron/refresh-tiktok-tokens",
      "schedule": "50 23 * * *"
    },
    {
      "path": "/api/cron/knowledge-updater",
      "schedule": "0 3 * * *"
    }
  ]
}
