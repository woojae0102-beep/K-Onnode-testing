# 방식 A: 개별 키 (이름은 반드시 VITE_ 로 시작)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

# 방식 B: 한 줄 JSON (있으면 방식 A보다 우선)
# VITE_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}

# 선택: Firestore 경로의 appId 세그먼트
# VITE_APP_ID=onnode-realtime-demo

# Gemini (AI 코치)
# VITE_GEMINI_API_KEY=
# VITE_GEMINI_MODEL=gemini-1.5-flash

# -----------------------------------------------------------------------------
# 서버 전용 키 (VITE_ 없음 — /api 서버리스 함수에서만 사용)
# -----------------------------------------------------------------------------

# YouTube Data API v3 — 탐색 탭의 트렌딩/안무/노래/챌린지 TOP 20 자동 수집
#   발급: https://console.cloud.google.com/apis/credentials 에서 API 키 생성 후
#         "YouTube Data API v3" 사용 설정
# YOUTUBE_API_KEY=

# Anthropic API — 기획사 오디션 심사위원 AI 코멘트
#   발급: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Cron 보호 시크릿 (선택) — 트렌딩 갱신 및 Instagram/TikTok 토큰 자동 갱신 API 보호
# CRON_SECRET=
# node-cron 상시 스케줄러가 호출할 앱 URL (로컬 기본값: http://localhost:5173)
# SCHEDULER_BASE_URL=https://your-domain.com

# ElevenLabs — 목소리 클론 + AI 모범창/교정 발음 TTS
#   발급: https://elevenlabs.io/app/settings/api-keys
# VITE_ELEVENLABS_API_KEY=   # (클라이언트 직접 호출 시만, 권장: 서버 키만 사용)
# ELEVENLABS_API_KEY=

# OpenAI — Whisper 음성→텍스트 (보컬/한국어 발음 분석)
#   발급: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Spotify Web API — 곡 페르소나(BPM, 에너지, 감성 등) 분석용
#   발급: https://developer.spotify.com/dashboard (앱 생성 → Client ID / Secret)
#   미설정 시: 곡 검색은 비활성화되고, 곡명/아티스트 텍스트만으로 휴리스틱 분석 동작
# VITE_SPOTIFY_CLIENT_ID=   # (선택, 대부분 서버 토큰 경로 사용)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# 쇼츠 SNS 업로드 OAuth — 클라이언트에는 앱 ID/키만, Secret/토큰은 서버에서만 사용
# Google Cloud Console OAuth Client
# VITE_GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Facebook Developers App / Instagram Graph API
# VITE_FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# TikTok Developers Content Posting API
# VITE_TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# 소셜 로그인 (카카오)
# -----------------------------------------------------------------------------
# Kakao Developers에서 무료 앱 등록 후 발급되는 "JavaScript 키" 입니다.
# https://developers.kakao.com/console/app -> 내 애플리케이션 -> 앱 설정 -> 앱 키
# VITE_KAKAO_APP_KEY=
# 로컬/배포 환경별 카카오 Redirect URI
# Kakao Developers -> 카카오 로그인 -> Redirect URI에 둘 다 등록해야 합니다.
# VITE_KAKAO_REDIRECT_URI_DEV=http://localhost:5173/oauth/callback/kakao
# VITE_KAKAO_REDIRECT_URI_PROD=https://k-onnode.vercel.app/oauth/callback/kakao
# Kakao Developers -> 앱 키 -> REST API 키 (서버 전용, VITE_ 없음)
# SDK v2 redirect 로그인에서 authorization code를 access token으로 교환할 때 필요합니다.
# KAKAO_REST_API_KEY=
# Kakao Developers -> 카카오 로그인 -> 보안 -> Client Secret을 "사용함"으로 켠 경우에만 필요합니다.
# KAKAO_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Firebase Admin (서버 전용) — 카카오 Custom Token, 토큰 검증, 결제 웹훅
# Firebase Console -> 프로젝트 설정 -> 서비스 계정 -> 새 비공개 키 생성
# 다운로드된 JSON에서 project_id / client_email / private_key 를 그대로 옮겨담으세요.
# private_key 내부의 줄바꿈은 \n 으로 이스케이프 해야 합니다.
# -----------------------------------------------------------------------------
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------------------------------
# Vercel 배포 체크리스트
# -----------------------------------------------------------------------------
# 1. Vercel 프로젝트 연결 후 위 서버 env를 Production/Preview에 등록
# 2. Kakao Redirect URI에 https://<your-domain>/oauth/callback/kakao 추가
# 3. SNS Redirect URI에 아래 주소를 각 플랫폼 콘솔에 등록
#    https://<your-domain>/auth/youtube/callback
#    https://<your-domain>/auth/instagram/callback
#    https://<your-domain>/auth/tiktok/callback
# 4. Firebase Authorized domains에 Vercel 도메인 추가
# 5. Firebase Storage bucket이 VITE_FIREBASE_STORAGE_BUCKET에 설정되어 있는지 확인
# 6. 카메라/마이크는 HTTPS에서만 동작 (Vercel 기본 HTTPS OK)
# 7. 최소 필수: VITE_FIREBASE_*, ANTHROPIC_API_KEY, FIREBASE_ADMIN (카카오 로그인 시)
