rules_version = '2';
// ONNODE TV 연결 + WebRTC 시그널링용 예시 규칙
// Firebase Console → Firestore → 규칙에 붙여넣은 뒤 프로젝트에 맞게 appId를 확인하세요.

service cloud.firestore {
  match /databases/{database}/documents {
    // TV Studio 세션 (점수·피드백·스켈레톤 동기화)
    match /artifacts/{appId}/public/data/tvSessions/{sessionId} {
      allow read, write: if request.auth != null;
    }

    // WebRTC 시그널링 (offer/answer/ICE)
    match /artifacts/{appId}/public/data/sessions/{sessionId}/webrtc/{docId} {
      allow read, write: if request.auth != null;
    }

    match /artifacts/{appId}/public/data/sessions/{sessionId}/webrtcIce/{iceId} {
      allow read, write: if request.auth != null;
    }
  }
}
